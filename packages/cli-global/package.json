{
  "name": "cli-global",
  "version": "1.0.0",
  "description": "Global command-line interface for DATN2 AI Code Review",
  "type": "module",
  "main": "./bin/cli.js",
  "bin": {
    "ai-code-review": "./bin/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "eslint src/ bin/",
    "format:check": "prettier --check src/ bin/",
