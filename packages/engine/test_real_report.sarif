  "runs": [
    {
      "tool": {
        "driver": {
          "name": "opengrep",
          "rules": [
            {
              "id": "javascript.lang.security.audit.detect-non-literal-regexp.detect-non-literal-regexp",
              "shortDescription": {
                "text": "RegExp() called with a `patterns` function argument, this might allow an attacker to cause a Regular Expression Denial-of-Service (ReDoS) within your application as RegExP blocks the main thread. For this reason, it is recommended to use hardcoded regexes instead. If your regex is run on user-controlled input, consider performing input validation or use a regex checking/sanitization library such as https://www.npmjs.com/package/recheck to verify that the regex does not appear vulnerable to ReDoS."
              }
            },
            {
              "id": "no-silent-except",
              "shortDescription": {
                "text": "Silent exception handler detected (except: pass). Log or handle the error."
              }
            },
            {
              "id": "no-print-statements",
              "shortDescription": {
                "text": "print() statement found in non-main code. Use logger instead."
              }
            },
            {
              "id": "javascript.lang.security.detect-child-process.detect-child-process",
              "shortDescription": {
                "text": "Detected calls to child_process from a function argument `args`. This could lead to a command injection if the input is user controllable. Try to avoid calls to child_process, and if it is needed ensure user input is correctly sanitized or sandboxed. "
              }
            },
            {
              "id": "no-console-log-in-handler",
              "shortDescription": {
                "text": "console.log() used inside Express route handler. Use a proper logger (e.g., winston, pino) to avoid information leakage in production."
              }
            },
            {
              "id": "no-child-process-in-handler",
              "shortDescription": {
                "text": "child_process usage inside Express route handler. Executing system commands from request handlers is a Remote Code Execution (RCE) risk. Move to a background worker or queue."
              }
            },
            {
              "id": "javascript.express.security.audit.xss.direct-response-write.direct-response-write",
              "shortDescription": {
                "text": "Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."
              }
            },
            {
              "id": "javascript.lang.security.audit.path-traversal.path-join-resolve-traversal.path-join-resolve-traversal",
              "shortDescription": {
                "text": "Detected possible user input going into a `path.join` or `path.resolve` function. This could possibly lead to a path traversal vulnerability,  where the attacker can access arbitrary files stored in the file system. Instead, be sure to sanitize or validate user input first."
              }
            },
            {
              "id": "no-hardcoded-creds",
              "shortDescription": {
                "text": "Hardcoded credential detected. Use environment variables or a secrets manager."
              }
            },
            {
              "id": "python.lang.security.insecure-hash-algorithms.insecure-hash-algorithm-sha1",
              "shortDescription": {
                "text": "Detected SHA1 hash algorithm which is considered insecure. SHA1 is not collision resistant and is therefore not suitable as a cryptographic signature. Use SHA256 or SHA3 instead."
              }
            },
            {
              "id": "python.lang.security.audit.dynamic-urllib-use-detected.dynamic-urllib-use-detected",
              "shortDescription": {
                "text": "Detected a dynamic value being used with urllib. urllib supports 'file://' schemes, so a dynamic value controlled by a malicious actor may allow them to read arbitrary files. Audit uses of urllib calls to ensure user data cannot control the URLs, or consider using the 'requests' library instead."
              }
            }
          ]
        }
      },
