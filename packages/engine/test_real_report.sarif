              "physicalLocation": {
                "artifactLocation": {
                  "uri": ""
                },
                "region": {
                  "snippet": {
                    "text": "\n\ndef _download_progress_hook(block_count: int, block_size: int, total_size: int):\n    \"\"\"Simple progress callback for ``urllib.request.urlretrieve``.\"\"\"\n    if total_size > 0:\n        downloaded = block_count * block_size / (1024 * 1024)\n        total_mb = total_size / (1024 * 1024)\n        print(\n            f\"\\r  Downloaded {downloaded:.1f} / {total_mb:.1f} MB\",\n            file=sys.stderr, end=\"\",\n        )\n\n"
                  }
                }
              }
            }
          ],
