{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node 'D:\\DATN2\\.codex\\hooks\\descriptive-name.cjs'"
          }
        ]
      },
      {
        "matcher": "Bash|Glob|Grep|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node 'D:\\DATN2\\.codex\\hooks\\scout-block.cjs'"
          },
          {
            "type": "command",
            "command": "node 'D:\\DATN2\\.codex\\hooks\\privacy-block.cjs'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node 'D:\\DATN2\\.codex\\hooks\\session-state.cjs'"
          },
          {
            "type": "command",
            "command": "node 'D:\\DATN2\\.codex\\hooks\\post-edit-simplify-reminder.cjs'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node 'D:\\DATN2\\.codex\\hooks\\session-init.cjs'"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node 'D:\\DATN2\\.codex\\hooks\\subagent-init.cjs'"
          }
        ]
      }
    ]
  }
}
